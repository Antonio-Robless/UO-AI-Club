# ─────────────────────────────────────────────────────────────
# .env.example  —  Copy this to .env and fill in your keys
# ─────────────────────────────────────────────────────────────

# ── TomTom API (Free tier: 2,500 requests/day)
# Get your key at: https://developer.tomtom.com/
TOMTOM_API_KEY=191mFIJ0lx0rVc9Qfj4nMkBWiqklH1Iq

# ── HERE API (Free tier: 250,000 requests/month)
# Get your key at: https://developer.here.com/
HERE_API_KEY=your_here_key_here

# -- Google Maps API
GOOGLE_MAPS_KEY=AIzaSyAmwRQYb_JBxQlbcGPWAQUdPp9NbwfTOJk

# ── Your city / region settings
# The server will use these as the default location for traffic lookups
# Find lat/lon at: https://www.latlong.net/
DEFAULT_LAT=44.0521
DEFAULT_LON=-123.0868
DEFAULT_CITY=Eugene, OR

# ── State code for gas price regional estimates
# Used when no paid gas price API is configured
# Options: OR, CA, WA, TX, NY, FL, IL (or "default" for US national avg)
STATE_CODE=OR
